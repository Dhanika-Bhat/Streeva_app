# Streeva Environment Variables

# MongoDB
MONGO_URI=mongodb://localhost:27017/streeva

# JWT
JWT_SECRET=streeva_secret_key_2024

# Server
PORT=5000

# Google Maps (Frontend - prefix with VITE_ for Vite)
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key

# Gemini AI (Backend)
GEMINI_API_KEY=your_gemini_api_key

# Cloudinary (Optional - for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
